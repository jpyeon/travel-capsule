# Copy this file to .env.local and fill in your Supabase project credentials.
# Never commit .env.local — it contains secrets.
#
# Find these values at: https://supabase.com/dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Gemini API key — server-side only (no NEXT_PUBLIC_ prefix).
# Used by /pages/api/gemini/* route handlers.
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
